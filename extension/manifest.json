{
  "manifest_version": 3,
  "name": "知网 AI 分析包助手",
  "version": "0.1.0",
  "description": "采集知网页面中的论文题录、摘要和关键词，并导出适合 AI 分析的文献材料。",
  "permissions": ["activeTab", "scripting", "storage", "downloads", "tabs"],
  "host_permissions": ["https://*.cnki.net/*", "https://*.cnki.com.cn/*", "http://127.0.0.1:3000/*"],
  "action": {
    "default_popup": "extension/src/popup/popup.html",
    "default_title": "知网 AI 分析包助手"
  },
  "background": {
    "service_worker": "assets/serviceWorker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://*.cnki.net/*", "https://*.cnki.com.cn/*"],
      "js": ["assets/content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
